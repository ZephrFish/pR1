# pR1 URL Shortener - Environment Configuration Example
# Copy this file to .dev.vars for local development

# ============================================================================
# CRITICAL SECURITY CONFIGURATION
# ============================================================================

# ADMIN_PASSWORD - Required for admin panel access
# SECURITY REQUIREMENTS (enforced by the application):
# - Minimum 12 characters
# - At least one uppercase letter (A-Z)
# - At least one lowercase letter (a-z)
# - At least one number (0-9)
# - At least one special character (!@#$%^&*()_+-=[]{};\':"|,.<>?/)
# - Must not contain common weak patterns (password123, admin123456, etc.)
#
# IMPORTANT: Never commit this password to version control!
# For production: Set via GitHub Secrets or Cloudflare dashboard
# For development: Set in .dev.vars (which is gitignored)
#
# Example strong password: MyS3cur3P@ssw0rd!2024
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ============================================================================
# DOMAIN CONFIGURATION
# ============================================================================

# Your custom domain (must be added to Cloudflare)
DOMAIN=yourdomain.com

# ============================================================================
# SECURITY OPTIONS
# ============================================================================

# ALLOW_HTTP - Allow HTTP URLs to be shortened (not just HTTPS)
# Default: false (more secure)
# Set to true if you need to shorten HTTP URLs
# WARNING: HTTP URLs are not encrypted and can be intercepted
ALLOW_HTTP=false

# ALLOW_PRIVATE_IPS - Allow private/internal IP addresses in URLs
# Default: false (prevents SSRF attacks)
# Set to true for testing or internal network URL shortening
# WARNING: Enabling this may expose internal network resources
ALLOW_PRIVATE_IPS=false

# ============================================================================
# CLOUDFLARE DEPLOYMENT (for CI/CD and manual deployment)
# ============================================================================

# Cloudflare API Token - Get from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions:
# - Account > Workers KV Storage > Edit
# - Account > Workers Scripts > Edit
# - Zone > Workers Routes > Edit
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Cloudflare Account ID - Find in: Cloudflare Dashboard > Workers & Pages
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# ============================================================================
# CLOUDFLARE KV NAMESPACE IDs
# ============================================================================
# These are set in wrangler.toml - included here for reference
# Get these by running: npx wrangler kv:namespace create "URL_STORE"

# URL_STORE_ID=your_url_store_id_here
# URL_STORE_PREVIEW_ID=your_preview_id_here
# ANALYTICS_ID=your_analytics_id_here
# ANALYTICS_PREVIEW_ID=your_preview_id_here

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
#
# Local Development:
# 1. Copy this file to .dev.vars
# 2. Update ADMIN_PASSWORD with a strong password
# 3. Run: npm run dev
#
# GitHub Actions Deployment:
# 1. Set ADMIN_PASSWORD in GitHub repository secrets
# 2. Set CLOUDFLARE_API_TOKEN in GitHub repository secrets
# 3. Push to master branch to trigger auto-deployment
#
# Manual Cloudflare Deployment:
# 1. Set environment variables in Cloudflare dashboard
# 2. Or use: wrangler secret put ADMIN_PASSWORD
# 3. Deploy: npm run deploy
#
